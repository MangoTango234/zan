<Window x:Class="Zan.Views.TransformHud"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False" ShowActivated="False"
        Topmost="True" WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True">
    <Border Background="#EE202020" CornerRadius="10" Padding="18,12">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="●" Foreground="#5AC8FA" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock x:Name="Label" Foreground="White" FontSize="14" VerticalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
