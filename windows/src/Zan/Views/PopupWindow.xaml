<Window x:Class="Zan.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zan"
        Width="460" SizeToContent="Height"
        MinHeight="160" MaxHeight="520"
        ResizeMode="CanResize"
        Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" FontWeight="SemiBold" FontSize="14"
                   Margin="0,0,0,8" TextTrimming="CharacterEllipsis" />

        <TextBox x:Name="BodyText" Grid.Row="1"
                 IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                 BorderThickness="0" Background="Transparent"
                 VerticalScrollBarVisibility="Auto" MinHeight="80" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Copy" Padding="14,5" Click="Copy_Click" />
            <Button Content="Close" Padding="14,5" Margin="8,0,0,0" Click="Close_Click" IsDefault="True" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
